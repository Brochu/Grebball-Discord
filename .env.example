# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real tokens or webhook URLs.

# --- Discord ---
# Bot token from the Discord Developer Portal (Bot > Reset Token). KEEP SECRET.
DISCORD_TOKEN=your-bot-token-here
# Server (guild) the bot registers its slash commands to. Right-click your
# server > Copy Server ID (Developer Mode must be enabled).
GUILD_ID=000000000000000000
# Discord webhook the bot posts weekly/playoff results to. KEEP SECRET.
RESULTS_WEBHOOK=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx
# Optional: webhook used by the startup weekly reminder. Omit to disable.
#WEEKLY_WEBHOOK=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx

# --- Pool / season config ---
POOL_ID=1
CONF_SEASON=2025

# --- External data sources (defaults shown; usually no need to change) ---
DATA_URL=https://site.api.espn.com/apis/site/v2/sports/football/nfl/scoreboard
STANDINGS_URL=https://site.web.api.espn.com/apis/v2/sports/football/nfl/standings
# Optional: only required by the /blame command.
#BLAME_URL=

# --- Web pick app ---
# Base URL of the local Express pick app, embedded in pick links.
PICKS_URL=http://localhost:3000

# --- Database ---
# SQLite file shared by the bot and the web app (relative to repo root).
DATABASE_URL=sqlite:local/local.db
